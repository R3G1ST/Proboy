{
    "luci-app-proboy": {
        "description": "Grant UCI and RPC access to Proboy",
        "read": {
            "file": {
                "/etc/init.d/proboy": ["exec"],
                "/etc/init.d/rpcd": ["exec"],
                "/opt/proboy/scripts/proboy.sh": ["exec"],
                "/opt/proboy/VERSION": ["read"],
                "/bin/df": ["exec"],
                "/bin/ip": ["exec"],
                "/bin/uname": ["exec"],
                "/bin/kill": ["exec"],
                "/bin/nproc": ["exec"],
                "/usr/bin/nproc": ["exec"],
                "/proc/cpuinfo": ["read"],
                "/proc/meminfo": ["read"],
                "/proc/uptime": ["read"],
                "/proc/net/route": ["read"],
                "/tmp/resolv.conf": ["read"],
                "/tmp/resolv.conf.d/resolv.conf.auto": ["read"],
                "/tmp/sysinfo/model": ["read"],
                "/etc/openwrt_release": ["read"]
            },
            "ubus": {
                "service": ["list"]
            },
            "uci": ["proboy"]
        },
        "write": {
            "uci": ["proboy"],
            "file": {
                "/etc/init.d/proboy": ["exec"]
            }
        }
    }
}
